{
  "name": "smart-color-picker",
  "version": "1.1.0",
  "description": "Self-contained color picker widget (solid, gradient, alpha, presets) — single HTML, zero dependencies.",
  "main": "smart-color-picker.html",
  "files": ["smart-color-picker.html"],
  "keywords": ["color-picker", "gradient", "widget", "spa", "standalone", "smart-widget"],
  "browser": "smart-color-picker.html",
  "cdn": {
    "jsdelivr": "release/smart-color-picker/smart-color-picker.html",
    "type": "html-spa"
  },
  "api": {
    "global": "SmartColorPicker",
    "config": "SmartColorPickerConfig",
    "messages": {
      "in": ["scp:open", "scp:close", "scp:set", "scp:setTheme"],
      "out": ["scp:color", "scp:commit", "scp:closed"]
    }
  }
}
